/* Light theme — high contrast for dialogs + main */
QWidget {
  font-size: 12pt;
  color: #1a1a1a;
  selection-background-color: #264f78;
  selection-color: #ffffff;
}

QMainWindow,
QDialog,
QWizard,
QWizardPage,
QFrame {
  background-color: #f3f3f3;
  color: #1a1a1a;
}

QLabel {
  background-color: transparent;
  color: #1a1a1a;
}

QWizard > QWidget > QLabel,
QDialog QLabel {
  color: #1a1a1a;
}

QLineEdit,
QTextEdit,
QPlainTextEdit,
QSpinBox,
QDoubleSpinBox {
  background-color: #ffffff;
  color: #0a0a0a;
  border: 1px solid #888888;
  border-radius: 4px;
  padding: 6px 8px;
  selection-background-color: #264f78;
  selection-color: #ffffff;
}

QLineEdit:disabled,
QTextEdit:disabled,
QSpinBox:disabled,
QComboBox:disabled {
  background-color: #eeeeee;
  color: #666666;
}

QComboBox {
  background-color: #ffffff;
  color: #0a0a0a;
  border: 1px solid #888888;
  border-radius: 4px;
  padding: 4px 8px;
}

QComboBox QAbstractItemView {
  background-color: #ffffff;
  color: #0a0a0a;
  selection-background-color: #264f78;
  selection-color: #ffffff;
  border: 1px solid #888888;
}

QListWidget {
  background-color: #ffffff;
  color: #1a1a1a;
  border: 1px solid #cccccc;
}

QListWidget::item:selected {
  background-color: #264f78;
  color: #ffffff;
}

QTableWidget {
  background-color: #ffffff;
  color: #1a1a1a;
  gridline-color: #cccccc;
  border: 1px solid #cccccc;
}

QHeaderView::section {
  background-color: #e8e8e8;
  color: #1a1a1a;
  padding: 6px;
  border: 1px solid #cccccc;
}

QTabWidget::pane {
  border: 1px solid #cccccc;
  background-color: #f3f3f3;
}

QTabBar::tab {
  background-color: #e0e0e0;
  color: #333333;
  padding: 8px 16px;
}

QTabBar::tab:selected {
  background-color: #006cbd;
  color: #ffffff;
}

QPushButton {
  background-color: #006cbd;
  color: #ffffff;
  padding: 8px 16px;
  border-radius: 4px;
  border: 1px solid #005a9e;
}

QPushButton:hover {
  background-color: #0078d4;
}

QPushButton:disabled {
  background-color: #cccccc;
  color: #666666;
}

QCheckBox,
QRadioButton {
  color: #1a1a1a;
  spacing: 8px;
}

QMenuBar {
  background-color: #f0f0f0;
  color: #1a1a1a;
}

QMenu {
  background-color: #ffffff;
  color: #1a1a1a;
  border: 1px solid #cccccc;
}

QMenu::item:selected {
  background-color: #264f78;
  color: #ffffff;
}

QProgressBar {
  background-color: #e8e8e8;
  color: #1a1a1a;
  border: 1px solid #cccccc;
  border-radius: 4px;
  text-align: center;
  min-height: 22px;
}

QProgressBar::chunk {
  background-color: #006cbd;
  border-radius: 3px;
}

QStatusBar {
  background-color: #006cbd;
  color: #ffffff;
}

QMessageBox {
  background-color: #f3f3f3;
}

QMessageBox QLabel {
  color: #1a1a1a;
  min-width: 280px;
}

QSplitter::handle {
  background-color: #cccccc;
}

QWizard QPushButton,
QDialogButtonBox QPushButton {
  min-width: 88px;
}
