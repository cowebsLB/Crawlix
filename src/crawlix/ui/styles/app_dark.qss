/* Dark theme — semantic colors interpolated at load (design_tokens.py). */
QWidget {
  font-size: 12pt;
  color: %%text_primary%%;
  selection-background-color: %%accent_selection%%;
  selection-color: %%text_inverse%%;
}

QMainWindow,
QDialog,
QWizard,
QWizardPage,
QFrame {
  background-color: %%surface_base%%;
  color: %%text_primary%%;
}

QLabel {
  background-color: transparent;
  color: %%text_primary%%;
}

QWizard > QWidget > QLabel,
QDialog QLabel {
  color: %%text_primary%%;
}

QLineEdit,
QTextEdit,
QPlainTextEdit,
QSpinBox,
QDoubleSpinBox {
  background-color: %%surface_sunken%%;
  color: %%text_inverse%%;
  border: 1px solid %%border_strong%%;
  border-radius: %%radius_sm%%;
  padding: %%space_8%% 8px;
  selection-background-color: %%accent_selection%%;
  selection-color: %%text_inverse%%;
}

QLineEdit:disabled,
QTextEdit:disabled,
QSpinBox:disabled,
QComboBox:disabled {
  background-color: %%surface_disabled%%;
  color: %%text_disabled%%;
  border: 1px solid %%border_muted%%;
}

QComboBox {
  background-color: %%surface_sunken%%;
  color: %%text_inverse%%;
  border: 1px solid %%border_strong%%;
  border-radius: %%radius_sm%%;
  padding: %%space_4%% 8px;
  min-height: 1.2em;
}

QComboBox QAbstractItemView {
  background-color: %%surface_overlay%%;
  color: %%text_primary%%;
  selection-background-color: %%accent_selection%%;
  selection-color: %%text_inverse%%;
  border: 1px solid %%border_muted%%;
}

QComboBox::drop-down {
  border: none;
  width: 24px;
}

QListWidget {
  background-color: %%surface_sunken%%;
  color: %%text_primary%%;
  border: 1px solid %%border_subtle%%;
}

QListWidget::item:selected {
  background-color: %%accent_selection%%;
  color: %%text_inverse%%;
}

QListWidget::item:hover {
  background-color: %%surface_disabled%%;
}

QTableWidget {
  background-color: %%surface_sunken%%;
  color: %%text_primary%%;
  gridline-color: %%border_default%%;
  border: 1px solid %%border_subtle%%;
}

QHeaderView::section {
  background-color: %%surface_raised%%;
  color: %%text_primary%%;
  padding: %%space_8%%;
  border: 1px solid %%border_default%%;
}

QTabWidget::pane {
  border: 1px solid %%border_default%%;
  background-color: %%surface_base%%;
}

QTabBar::tab {
  background-color: %%surface_raised%%;
  color: %%text_secondary%%;
  padding: %%space_8%% 16px;
  border: 1px solid %%border_default%%;
}

QTabBar::tab:selected {
  background-color: %%accent_action%%;
  color: %%text_on_accent%%;
}

QPushButton {
  background-color: %%accent_action%%;
  color: %%text_on_accent%%;
  padding: %%space_8%% 16px;
  border-radius: %%radius_sm%%;
  border: 1px solid %%accent_focus%%;
}

QPushButton:hover {
  background-color: %%accent_hover%%;
}

QPushButton:pressed {
  background-color: %%accent_pressed%%;
}

QPushButton:disabled {
  background-color: %%border_muted%%;
  color: %%text_muted%%;
  border: 1px solid %%border_muted%%;
}

QCheckBox,
QRadioButton {
  color: %%text_primary%%;
  spacing: %%space_8%%;
}

QCheckBox::indicator,
QRadioButton::indicator {
  width: 18px;
  height: 18px;
}

QMenuBar {
  background-color: %%surface_raised%%;
  color: %%text_primary%%;
}

QMenuBar::item:selected {
  background-color: %%accent_selection%%;
}

QMenu {
  background-color: %%surface_raised%%;
  color: %%text_primary%%;
  border: 1px solid %%border_default%%;
}

QMenu::item:selected {
  background-color: %%accent_selection%%;
  color: %%text_inverse%%;
}

QProgressBar {
  background-color: %%surface_disabled%%;
  color: %%text_primary%%;
  border: 1px solid %%border_strong%%;
  border-radius: %%radius_sm%%;
  text-align: center;
  min-height: 22px;
}

QProgressBar::chunk {
  background-color: %%accent_action%%;
  border-radius: %%radius_sm%%;
}

QStatusBar {
  background-color: %%statusbar_bg%%;
  color: %%statusbar_fg%%;
}

QScrollBar:vertical {
  background: %%surface_scroll%%;
  width: 14px;
}

QScrollBar::handle:vertical {
  background: %%scrollbar_thumb%%;
  min-height: 24px;
  border-radius: %%radius_sm%%;
}

QScrollBar:horizontal {
  background: %%surface_scroll%%;
  height: 14px;
}

QScrollBar::handle:horizontal {
  background: %%scrollbar_thumb%%;
  min-width: 24px;
  border-radius: %%radius_sm%%;
}

QMessageBox {
  background-color: %%surface_base%%;
}

QMessageBox QLabel {
  color: %%text_primary%%;
  min-width: 280px;
}

QMessageBox QPushButton {
  min-width: 80px;
}

QSplitter::handle {
  background-color: %%border_default%%;
}

QWizard QPushButton,
QDialogButtonBox QPushButton {
  min-width: 88px;
}

/* Product shell chrome (MainWindow refactor targets) */
QWidget#TopCommandStrip {
  background-color: %%surface_raised%%;
  border-bottom: 1px solid %%border_default%%;
}

QWidget#NavRailColumn {
  background-color: transparent;
}

QWidget#PageHost {
  background-color: %%surface_base%%;
}

QWidget#JobCenter {
  background-color: %%surface_base%%;
  border-top: 1px solid %%border_default%%;
}

/* Semantic components (prefer objectName + properties over ad hoc rules) */
QFrame#SectionCard {
  background-color: %%surface_sunken%%;
  border: 1px solid %%border_subtle%%;
  border-radius: %%radius_md%%;
}

QPushButton[variant="destructive"] {
  background-color: %%status_danger%%;
  color: %%text_on_accent%%;
  border: 1px solid %%priority_now%%;
}

QPushButton[variant="secondary"] {
  background-color: %%surface_raised%%;
  color: %%text_primary%%;
  border: 1px solid %%border_strong%%;
}

QLabel[role="metadata"] {
  color: %%text_muted%%;
  font-size: 10pt;
}
